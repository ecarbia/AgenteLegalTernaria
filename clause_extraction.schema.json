{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ternaria.local/schemas/legalops/contract-analysis-v1.json",
  "title": "LegalOps Contract Analysis v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "document",
    "summary",
    "clauses",
    "overall_risk",
    "compliance_checks",
    "human_review",
    "generated_at"
  ],
  "properties": {
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "document_name",
        "source_type",
        "repository_path",
        "ingestion_timestamp"
      ],
      "properties": {
        "document_id": {
          "type": "string",
          "minLength": 1
        },
        "document_name": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": ["pdf", "docx", "txt"]
        },
        "repository_path": {
          "type": "string",
          "minLength": 1
        },
        "hash_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        },
        "ingestion_timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parties", "object", "term", "governing_law", "jurisdiction"],
      "properties": {
        "parties": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "object": {
          "type": "string",
          "minLength": 1
        },
        "term": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["found", "partial", "not_found", "ambiguous"]
            },
            "start_date": {
              "type": "string",
              "format": "date"
            },
            "end_date": {
              "type": "string",
              "format": "date"
            },
            "duration_text": {
              "type": "string"
            }
          }
        },
        "governing_law": {
          "type": "string"
        },
        "jurisdiction": {
          "type": "string"
        }
      }
    },
    "clauses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "clause_type",
          "status",
          "extracted_text",
          "evidence",
          "risk"
        ],
        "properties": {
          "clause_type": {
            "type": "string",
            "enum": [
              "parties",
              "object",
              "term",
              "payments",
              "termination",
              "liability",
              "indemnification",
              "confidentiality",
              "intellectual_property",
              "jurisdiction",
              "compliance"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["found", "partial", "not_found", "ambiguous"]
          },
          "extracted_text": {
            "type": "string"
          },
          "normalized_data": {
            "type": "object",
            "additionalProperties": true
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["document_id", "snippet"],
              "properties": {
                "document_id": {
                  "type": "string",
                  "minLength": 1
                },
                "document_name": {
                  "type": "string"
                },
                "section": {
                  "type": "string"
                },
                "page": {
                  "type": "integer",
                  "minimum": 1
                },
                "paragraph": {
                  "type": "string"
                },
                "char_start": {
                  "type": "integer",
                  "minimum": 0
                },
                "char_end": {
                  "type": "integer",
                  "minimum": 0
                },
                "snippet": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 500
                }
              }
            }
          },
          "risk": {
            "type": "object",
            "additionalProperties": false,
            "required": ["level", "rationale", "probable_impact", "recommendation_initial"],
            "properties": {
              "level": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              },
              "probable_impact": {
                "type": "string",
                "minLength": 1
              },
              "recommendation_initial": {
                "type": "string",
                "minLength": 1
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },
    "overall_risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "score", "critical_flags"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "critical_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "compliance_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "status", "message"],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["pass", "warn", "fail", "not_evaluated"]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["document_id", "snippet"],
              "properties": {
                "document_id": {
                  "type": "string",
                  "minLength": 1
                },
                "page": {
                  "type": "integer",
                  "minimum": 1
                },
                "section": {
                  "type": "string"
                },
                "snippet": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 500
                }
              }
            }
          }
        }
      }
    },
    "human_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "reason", "review_status"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "review_status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "not_required"]
        },
        "reviewed_by": {
          "type": "string"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "review_notes": {
          "type": "string"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "disclaimer": {
      "type": "string",
      "default": "Analisis tecnico automatizado. Requiere validacion de abogado responsable."
    }
  }
}
